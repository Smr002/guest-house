---
import type { SupportedLocale } from '@app-types/i18n';
import type { Room } from '@app-types/room';
import type { SiteConfig } from '@app-types/site';
import type { Translations } from '@app-types/translations';
import Button from '@components/ui/Button.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import StayCalendar from '@components/ui/StayCalendar.astro';
import { getRoomContent } from '@utils/i18n';

interface Props {
  translations: Translations;
  site: SiteConfig;
  rooms: readonly Room[];
  lang: SupportedLocale;
}

const { translations, site, rooms, lang } = Astro.props;
const phoneHref = `tel:${site.contact.phone.replaceAll(' ', '')}`;
const whatsappHref = `https://wa.me/${site.contact.whatsapp.replaceAll('+', '')}`;
interface ContactRow {
  readonly label: string;
  readonly value: string;
  readonly href: string | undefined;
}

const contactRows = [
  { label: translations.contact.info.addressLabel, value: `${site.location.address}, ${site.location.city}`, href: site.location.googleMapsUrl },
  { label: translations.contact.info.phoneLabel, value: site.contact.phone, href: phoneHref },
  { label: translations.contact.info.emailLabel, value: site.contact.email, href: `mailto:${site.contact.email}` },
  { label: translations.contact.info.checkinLabel, value: site.hours.checkIn, href: undefined },
  { label: translations.contact.info.checkoutLabel, value: site.hours.checkOut, href: undefined },
  { label: translations.contact.info.receptionLabel, value: site.hours.reception, href: undefined },
] as const satisfies readonly ContactRow[];
---

<section id="contact" class="bg-light-stone py-section">
  <div class="container">
    <SectionHeader
      eyebrow={translations.contact.eyebrow}
      heading={translations.contact.heading}
      subheading={translations.contact.subheading}
    />

    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="grid gap-5">
        <div class="rounded-lg border border-stone-white bg-stone-white p-6 shadow-soft">
          <p class="mb-5 text-xs font-semibold uppercase tracking-wide text-valley-green">{translations.contact.processTitle}</p>
          <ol class="grid gap-4">
            {
              translations.contact.process.map((step: string, index: number) => (
                <li class="grid grid-cols-[2.25rem_1fr] gap-3">
                  <span class="flex h-9 w-9 items-center justify-center rounded-full bg-mountain-pine text-sm font-semibold text-stone-white">
                    {index + 1}
                  </span>
                  <span class="pt-1 text-sm leading-6 text-mountain-pine/80">{step}</span>
                </li>
              ))
            }
          </ol>
        </div>

        <div class="rounded-lg border border-stone-white bg-stone-white p-6 shadow-soft">
          <dl class="grid gap-5">
          {
            contactRows.map((row) => (
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-worn-stone">{row.label}</dt>
                <dd class="mt-1 text-base font-medium text-mountain-pine">
                  {row.href ? (
                    <a class="transition hover:text-valley-green" href={row.href}>
                      {row.value}
                    </a>
                  ) : (
                    row.value
                  )}
                </dd>
              </div>
            ))
          }
          </dl>

          <a
            class="mt-8 inline-flex min-h-11 w-full items-center justify-center rounded-md border border-valley-green px-5 py-3 text-sm font-semibold text-valley-green transition hover:bg-valley-green hover:text-stone-white"
            href={whatsappHref}
          >
            {translations.contact.form.whatsapp}
          </a>
        </div>
      </div>

      <form
        id="enquiry-form"
        class="grid gap-4 rounded-lg border border-stone-white bg-stone-white p-6 shadow-lift"
        action="/api/contact"
        method="post"
        novalidate
        data-success-message={translations.contact.form.success}
        data-error-message={translations.contact.form.error}
      >
        <div class="mb-1 border-b border-light-stone pb-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-valley-green">{translations.contact.eyebrow}</p>
          <p class="mt-2 font-display text-3xl italic leading-tight text-mountain-pine">{translations.hero.bookingTitle}</p>
          <p class="mt-2 text-sm leading-6 text-worn-stone">{translations.hero.directBooking}</p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2 text-sm font-medium text-mountain-pine">
            <span>{translations.contact.form.name}</span>
            <input
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              type="text"
              name="name"
              autocomplete="name"
              required
            />
          </label>
          <label class="grid gap-2 text-sm font-medium text-mountain-pine">
            <span>{translations.contact.form.email}</span>
            <input
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              type="email"
              name="email"
              autocomplete="email"
              required
            />
          </label>
        </div>

        <StayCalendar translations={translations} lang={lang} />

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2 text-sm font-medium text-mountain-pine">
            <span>{translations.contact.form.guests}</span>
            <input
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              type="number"
              name="guests"
              min="1"
              max="6"
              inputmode="numeric"
            />
          </label>
          <label class="grid gap-2 text-sm font-medium text-mountain-pine">
            <span>{translations.contact.form.room}</span>
            <select
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              name="room"
            >
              <option value="">{translations.contact.form.roomAny}</option>
              {
                rooms.map((room: Room) => {
                  const content = getRoomContent(room, lang);
                  return <option value={room.slug}>{content.name}</option>;
                })
              }
            </select>
          </label>
        </div>

        <label class="grid gap-2 text-sm font-medium text-mountain-pine">
          <span>{translations.contact.form.message}</span>
          <textarea
            class="min-h-32 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
            name="message"
            rows="4"
          ></textarea>
        </label>

        <Button type="submit" variant="primary" class="w-full">{translations.contact.form.submit}</Button>
        <p id="form-status" class="hidden text-center text-sm font-medium" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script lang="ts" is:inline>
  const form = /** @type {HTMLFormElement | null} */ (document.querySelector('#enquiry-form'));
  const statusElement = /** @type {HTMLParagraphElement | null} */ (document.querySelector('#form-status'));
  const stayEnquiryForm = /** @type {HTMLFormElement | null} */ (document.querySelector('[data-stay-enquiry-form]'));
  const contactSection = /** @type {HTMLElement | null} */ (document.querySelector('#contact'));
  const desktopDateQuery = window.matchMedia('(min-width: 768px)');

  function setFormValue(targetForm, name, value) {
    const field = targetForm?.elements.namedItem(name);
    if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) {
      field.value = value;
      field.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }

  function copyStayValues(formData) {
    if (form === null) {
      return;
    }

    ['checkin', 'checkout', 'guests', 'room'].forEach((fieldName) => {
      const value = formData.getAll(fieldName).find((entry) => String(entry).trim() !== '');
      if (typeof value === 'string') {
        setFormValue(form, fieldName, value);
      }
    });
  }

  function setDisabled(elements, isDisabled) {
    elements.forEach((element) => {
      if (element instanceof HTMLInputElement || element instanceof HTMLSelectElement || element instanceof HTMLButtonElement) {
        element.disabled = isDisabled;
      }
    });
  }

  function syncResponsiveHeroDates() {
    const useDesktopCalendar = desktopDateQuery.matches;
    setDisabled(document.querySelectorAll('[data-mobile-stay-fields] input'), useDesktopCalendar);
    setDisabled(document.querySelectorAll('[data-desktop-stay-calendar] input'), !useDesktopCalendar);
  }

  function focusEnquiryForm() {
    const nameField = form?.elements.namedItem('name');
    if (nameField instanceof HTMLInputElement) {
      window.setTimeout(() => nameField.focus(), 350);
    }
  }

  function scrollToContact() {
    contactSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function formDataToPayload(formData) {
    const payload = {};
    formData.forEach((value, key) => {
      payload[key] = String(value);
    });
    return payload;
  }

  function showStatus(message, isSuccess) {
    if (statusElement === null) {
      return;
    }

    statusElement.textContent = message;
    statusElement.classList.remove('hidden', 'text-red-700', 'text-valley-green');
    statusElement.classList.add(isSuccess ? 'text-valley-green' : 'text-red-700');
  }

  const today = new Date().toISOString().slice(0, 10);
  document.querySelectorAll('input[type="date"]').forEach((input) => {
    if (input instanceof HTMLInputElement && input.min === '') {
      input.min = today;
    }
  });
  syncResponsiveHeroDates();
  desktopDateQuery.addEventListener('change', syncResponsiveHeroDates);

  stayEnquiryForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    copyStayValues(new FormData(stayEnquiryForm));
    scrollToContact();
    focusEnquiryForm();
  });

  document.querySelectorAll('[data-enquiry-room]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const room = link instanceof HTMLElement ? link.dataset['enquiryRoom'] : '';
      if (!room || form === null) {
        return;
      }

      event.preventDefault();
      setFormValue(form, 'room', room);
      scrollToContact();
      focusEnquiryForm();
    });
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const endpoint = form.action;
    const payload = formDataToPayload(new FormData(form));

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error('Request failed');
      }

      showStatus(form.dataset['successMessage'] ?? '', true);
      form.reset();
    } catch {
      showStatus(form.dataset['errorMessage'] ?? '', false);
    }
  });
</script>
