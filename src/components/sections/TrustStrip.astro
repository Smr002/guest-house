---
import type { Translations } from '@app-types/translations';

interface Props {
  translations: Translations;
}

const { translations } = Astro.props;
const trustItems = [
  { value: translations.about.facts.roomsValue, label: translations.trustStrip.roomsLabel },
  { value: '5 min', label: translations.trustStrip.walkLabel },
  { value: translations.about.facts.breakfastValue, label: translations.trustStrip.breakfastLabel },
  { value: translations.trustStrip.replyValue, label: translations.trustStrip.replyLabel },
] as const satisfies readonly { readonly value: string; readonly label: string }[];
---

<section class="border-y border-light-stone bg-stone-white">
  <div class="container grid gap-px bg-light-stone sm:grid-cols-2 lg:grid-cols-4">
    {
      trustItems.map((item) => (
        <div class="bg-stone-white px-5 py-6 transition-colors hover:bg-sky-wash/50">
          <p class="font-display text-3xl italic leading-none text-mountain-pine">{item.value}</p>
          <p class="mt-2 text-sm font-medium leading-6 text-worn-stone">{item.label}</p>
        </div>
      ))
    }
  </div>
</section>
