---
import { Image } from 'astro:assets';
import type { SupportedLocale } from '@app-types/i18n';
import type { Room } from '@app-types/room';
import type { Translations } from '@app-types/translations';
import Button from '@components/ui/Button.astro';
import { getRoomContent } from '@utils/i18n';
import { getHeroImage } from '@utils/images';

interface Props {
  translations: Translations;
  rooms: readonly Room[];
  lang: SupportedLocale;
}

const { translations, rooms, lang } = Astro.props;
const heroImage = getHeroImage();
const trustItems = [
  translations.hero.trust.rating,
  translations.hero.trust.breakfast,
  translations.hero.trust.oldBazaar,
] as const satisfies readonly string[];
---

<section id="home" class="relative isolate overflow-hidden bg-mountain-pine">
  <div class="absolute inset-0 -z-10">
    <Image
      src={heroImage}
      alt={translations.hero.imageAlt}
      widths={[960, 1440, 1920]}
      sizes="100vw"
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-mountain-pine via-mountain-pine/72 to-mountain-pine/25"></div>
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-mountain-pine to-transparent"></div>
  </div>

  <div class="container grid min-h-[calc(100svh-4rem)] gap-8 py-12 lg:grid-cols-[1fr_440px] lg:items-center lg:py-16">
    <div class="max-w-4xl pt-8 lg:pt-0">
      <p class="mb-4 inline-flex rounded-full bg-stone-white/12 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-old-brass backdrop-blur">
        {translations.hero.eyebrow}
      </p>
      <div>
        <h1 class="text-hero italic leading-tight text-stone-white">{translations.hero.heading}</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-stone-white/78">{translations.hero.subheading}</p>
        <ul class="mt-7 flex flex-wrap gap-2">
          {
            trustItems.map((item: string) => (
              <li class="rounded-full border border-stone-white/20 bg-stone-white/10 px-3 py-2 text-sm font-medium text-stone-white backdrop-blur">
                {item}
              </li>
            ))
          }
        </ul>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button variant="primary" href="#contact">{translations.hero.ctaBook}</Button>
          <Button variant="ghost" href="#rooms">{translations.hero.ctaRooms}</Button>
        </div>
      </div>
    </div>

    <form
      class="rounded-lg border border-stone-white/20 bg-stone-white p-5 shadow-soft lg:p-6"
      action="#contact"
      method="get"
    >
      <div class="mb-5">
        <p class="font-display text-3xl italic text-mountain-pine">{translations.hero.bookingTitle}</p>
        <p class="mt-1 text-sm text-worn-stone">{translations.hero.directBooking}</p>
      </div>

      <div class="grid gap-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-semibold text-mountain-pine">
            <span>{translations.contact.form.checkin}</span>
            <input
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              type="date"
              name="checkin"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-mountain-pine">
            <span>{translations.contact.form.checkout}</span>
            <input
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              type="date"
              name="checkout"
            />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-[0.7fr_1.3fr]">
          <label class="grid gap-2 text-sm font-semibold text-mountain-pine">
            <span>{translations.contact.form.guests}</span>
            <input
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              type="number"
              name="guests"
              min="1"
              max="6"
              inputmode="numeric"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-mountain-pine">
            <span>{translations.contact.form.room}</span>
            <select
              class="min-h-11 rounded border border-light-stone px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-old-brass"
              name="room"
            >
              <option value="">{translations.contact.form.roomAny}</option>
              {
                rooms.map((room: Room) => {
                  const content = getRoomContent(room, lang);
                  return <option value={room.slug}>{content.name}</option>;
                })
              }
            </select>
          </label>
        </div>

        <Button type="submit" variant="primary" class="w-full">{translations.hero.checkAvailability}</Button>
      </div>
    </form>
  </div>
</section>
