---
import { Image } from 'astro:assets';
import type { SupportedLocale } from '@app-types/i18n';
import type { AmenityKey, Room } from '@app-types/room';
import type { Translations } from '@app-types/translations';
import AmenityTag from '@components/ui/AmenityTag.astro';
import Button from '@components/ui/Button.astro';
import { formatPrice } from '@utils/formatting';
import { getRoomContent, t } from '@utils/i18n';
import { getRoomImage } from '@utils/images';

interface Props {
  room: Room;
  lang: SupportedLocale;
  translations: Translations;
}

const { room, lang, translations } = Astro.props;
const content = getRoomContent(room, lang);
const formattedPrice = formatPrice(room.pricePerNight, room.currency, lang);
const displayAmenities: readonly AmenityKey[] = room.amenities.slice(0, 4);
const roomImage = getRoomImage(room.id);
const imageAlt = t(translations, 'accessibility.roomImage', { name: content.name });
type BestForKey = keyof Translations['rooms']['bestFor'];
const BEST_FOR_BY_ROOM = {
  'castle-view': 'couples',
  'courtyard-suite': 'slowStay',
  'old-town-double': 'explorers',
  'family-room': 'families',
} as const satisfies Readonly<Record<string, BestForKey>>;
const bestForKey = room.id in BEST_FOR_BY_ROOM
  ? BEST_FOR_BY_ROOM[room.id as keyof typeof BEST_FOR_BY_ROOM]
  : 'couples';
---

<article class="group flex h-full flex-col overflow-hidden rounded-lg border border-light-stone bg-white shadow-soft transition duration-200 hover:-translate-y-1 hover:shadow-lift">
  <div class="relative min-h-72 overflow-hidden bg-light-stone lg:min-h-80">
    <Image
      src={roomImage}
      alt={imageAlt}
      widths={[640, 960, 1280]}
      sizes="(min-width: 1024px) 50vw, 100vw"
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-x-5 top-5 flex flex-wrap gap-2">
      {room.featured ? (
        <span class="rounded-full bg-old-brass px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-mountain-pine">
          {translations.hero.trust.bestRate}
        </span>
      ) : null}
      <span class="rounded-full bg-mountain-pine/78 px-3 py-1.5 text-xs font-semibold text-stone-white backdrop-blur">
        {t(translations, 'rooms.guests', { count: room.capacity })}
      </span>
    </div>
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-mountain-pine/55 to-transparent opacity-80"></div>
  </div>

  <div class="flex flex-1 flex-col p-6 sm:p-7">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-valley-green">
          {translations.rooms.bestForLabel} {translations.rooms.bestFor[bestForKey]}
        </p>
        <h3 class="text-3xl italic leading-tight text-mountain-pine">{content.name}</h3>
        <p class="mt-3 max-w-2xl text-base leading-7 text-worn-stone">{content.shortDescription}</p>
      </div>
      <p class="inline-flex w-fit shrink-0 items-baseline gap-1.5 rounded-md border border-light-stone bg-stone-white px-3 py-2 shadow-line">
        <span class="text-xs font-semibold uppercase tracking-wide text-worn-stone">{translations.rooms.from}</span>
        <span class="font-display text-3xl leading-none text-mountain-pine">{formattedPrice}</span>
        <span class="text-xs text-worn-stone">{translations.rooms.perNight}</span>
      </p>
    </div>

    <div class="mt-6 grid gap-px overflow-hidden rounded-md border border-light-stone bg-light-stone sm:grid-cols-2">
      <span class="bg-stone-white px-4 py-3 text-sm font-semibold text-mountain-pine">
        {t(translations, 'rooms.guests', { count: room.capacity })}
      </span>
      <span class="bg-stone-white px-4 py-3 text-sm font-semibold text-mountain-pine">
        {t(translations, 'rooms.size', { size: room.sizeM2 })}
      </span>
    </div>

    <ul class="mt-5 flex flex-wrap gap-2">
      {
        displayAmenities.map((amenityKey: AmenityKey) => (
          <li>
            <AmenityTag amenityKey={amenityKey} label={translations.rooms.amenityLabels[amenityKey]} />
          </li>
        ))
      }
    </ul>

    <p class="mt-6 text-sm leading-7 text-mountain-pine/80">{content.description}</p>

    <div class="mt-auto flex flex-col gap-3 border-t border-light-stone pt-6 sm:flex-row">
      <a
        href="#contact"
        class="inline-flex min-h-11 w-full items-center justify-center rounded-md bg-old-brass px-6 py-3 text-sm font-semibold text-mountain-pine shadow-line transition-all duration-150 hover:-translate-y-0.5 hover:brightness-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-old-brass focus-visible:ring-offset-2 active:translate-y-0"
        data-enquiry-room={room.slug}
      >
        {translations.rooms.bookNow}
      </a>
      <Button href="#gallery" variant="outline" class="w-full">{translations.rooms.viewDetails}</Button>
    </div>
  </div>
</article>
