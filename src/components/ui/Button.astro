---
interface Props {
  variant: 'primary' | 'ghost' | 'outline';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
}

const { variant, href, type = 'button', class: className = '' } = Astro.props;

const baseClasses =
  'inline-flex min-h-11 items-center justify-center rounded px-6 py-3 text-sm font-medium transition-all duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-old-brass focus-visible:ring-offset-2';
const primaryClasses = 'bg-old-brass text-mountain-pine hover:brightness-95 active:scale-95';
const ghostClasses = 'border border-stone-white text-stone-white hover:bg-white/10 active:scale-95';
const outlineClasses =
  'border border-mountain-pine/20 text-mountain-pine hover:border-valley-green hover:text-valley-green active:scale-95';
const variantClasses = {
  primary: primaryClasses,
  ghost: ghostClasses,
  outline: outlineClasses,
} as const satisfies Record<Props['variant'], string>;
const classes = [baseClasses, variantClasses[variant], className].join(' ');
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
