---
import type { Experience } from '@app-types/experience';
import type { SupportedLocale } from '@app-types/i18n';
import type { Translations } from '@app-types/translations';
import { getRoomContent, t } from '@utils/i18n';

interface Props {
  experience: Experience;
  lang: SupportedLocale;
  translations: Translations;
}

const { experience, lang, translations } = Astro.props;
const content = getRoomContent(experience, lang);
const distanceKey =
  experience.travelMode === 'walk' ? 'experiences.walkingMinutes' : 'experiences.drivingMinutes';
const distanceLabel = t(translations, distanceKey, { count: experience.distanceMin });
---

<article class="rounded-lg border border-light-stone bg-white p-5 shadow-soft">
  <div class="flex items-start gap-4">
    <span class="flex h-11 w-11 flex-none items-center justify-center rounded bg-sky-wash text-valley-green">
      <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
        <path d={experience.icon} fill="currentColor"></path>
      </svg>
    </span>
    <div>
      <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-old-brass">{distanceLabel}</p>
      <h3 class="font-display text-2xl italic leading-tight text-mountain-pine">{content.name}</h3>
      <p class="mt-2 text-sm leading-6 text-worn-stone">{content.description}</p>
      <p class="mt-3 text-sm font-medium leading-6 text-valley-green">{content.tip}</p>
    </div>
  </div>
</article>
