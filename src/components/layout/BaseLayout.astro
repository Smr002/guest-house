---
import type { SupportedLocale } from '@app-types/i18n';
import { LOCALE_CONFIG } from '@app-types/i18n';
import '@styles/global.css';

interface Props {
  lang: SupportedLocale;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const direction = LOCALE_CONFIG[lang].direction;
---

<!doctype html>
<html lang={lang} dir={direction} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2d3a35" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
