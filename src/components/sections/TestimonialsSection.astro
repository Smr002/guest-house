---
import type { Translations } from '@app-types/translations';
import SectionHeader from '@components/ui/SectionHeader.astro';
import TestimonialCard from '@components/ui/TestimonialCard.astro';

interface Props {
  translations: Translations;
}

type Testimonial = Translations['testimonials']['items'][number];

const { translations } = Astro.props;
---

<section class="bg-stone-white py-section">
  <div class="container">
    <SectionHeader
      eyebrow={translations.testimonials.eyebrow}
      heading={translations.testimonials.heading}
      align="center"
    />

    <div class="grid gap-5 md:grid-cols-3">
      {
        translations.testimonials.items.map((testimonial: Testimonial) => (
          <TestimonialCard
            quote={testimonial.quote}
            name={testimonial.name}
            location={testimonial.location}
          />
        ))
      }
    </div>
  </div>
</section>
