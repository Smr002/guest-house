---
interface Props {
  quote: string;
  name: string;
  location: string;
}

const { quote, name, location } = Astro.props;
---

<figure class="rounded-lg border border-light-stone bg-white p-6 shadow-soft transition duration-200 hover:-translate-y-1 hover:shadow-lift">
  <div class="mb-4 flex gap-1 text-old-brass" aria-hidden="true">
    <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.8 1-6.1-4.4-4.3 6.1-.9L12 3Z" fill="currentColor"></path></svg>
    <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.8 1-6.1-4.4-4.3 6.1-.9L12 3Z" fill="currentColor"></path></svg>
    <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.8 1-6.1-4.4-4.3 6.1-.9L12 3Z" fill="currentColor"></path></svg>
    <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.8 1-6.1-4.4-4.3 6.1-.9L12 3Z" fill="currentColor"></path></svg>
    <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 17l-5.4 2.8 1-6.1-4.4-4.3 6.1-.9L12 3Z" fill="currentColor"></path></svg>
  </div>
  <blockquote class="text-base leading-8 text-mountain-pine">“{quote}”</blockquote>
  <figcaption class="mt-5 border-t border-light-stone pt-4">
    <p class="font-semibold text-mountain-pine">{name}</p>
    <p class="text-sm text-worn-stone">{location}</p>
  </figcaption>
</figure>
